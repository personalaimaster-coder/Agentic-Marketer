# ============================================================
# Marketing Agent — configuration template
# Copy this file to .env and fill in your own values.
# NEVER commit .env to git — only this .env.example template.
# ============================================================

# ------------------------------------------------------------
# GOOGLE CLOUD / VERTEX AI
# ------------------------------------------------------------
# Your GCP project ID — visible in the Cloud Console header bar.
GOOGLE_CLOUD_PROJECT=
# Vertex AI region. us-central1 has all Gemini + image models.
GOOGLE_CLOUD_LOCATION=us-central1
# Routes google-genai calls through Vertex AI instead of the public AI API.
# Set to FALSE only if you use a Google AI Studio API key instead.
GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GCS bucket for hosting post images (public read). Created by infra/setup.sh.
# Defaults to "<project>-post-images" if left blank.
GCS_BUCKET=

# ------------------------------------------------------------
# MODEL OVERRIDES (optional — defaults already set in config.py)
# ------------------------------------------------------------
# Fast, cheap model for structured JSON tasks (ranking, image prompts).
MODEL_FAST=gemini-2.5-flash-lite
# Smart model for brand copywriting and reflection.
MODEL_SMART=gemini-2.5-flash
# Image model that bakes the headline onto the generated image.
MODEL_IMAGE=gemini-2.5-flash-image

# ------------------------------------------------------------
# DEPLOYMENT (Cloud Run service + scheduler auth)
# ------------------------------------------------------------
# Cloud Run service name (used by go.sh / deploy.sh).
SERVICE_NAME=marketing-agent
# This service's own public URL (filled in automatically by go.sh after deploy).
SERVICE_URL=
# A shared secret so random callers can't trigger your endpoints.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SCHEDULER_SECRET=

# ------------------------------------------------------------
# BRAND — make this package your own (all optional; defaults in config.py)
# ------------------------------------------------------------
# The name of your brand / product.
BRAND_NAME=Acme
# A one-line description of what your brand is.
BRAND_TAGLINE=a product your audience loves
# Who you are talking to.
BRAND_AUDIENCE=your target audience
# The subject area your content lives in (drives topic ranking + research).
BRAND_DOMAIN=your product's topic area
# Visual identity guidance for generated images.
BRAND_COLORS=clean neutral palette with a single accent color
# Tone of voice for all copy.
BRAND_VOICE=clear, helpful, on-brand — never salesy or preachy
# Comma-separated criteria used to rank candidate topics, most important first.
RANKING_CRITERIA=relevance to the brand,emotional resonance with the audience,shareability
# Comma-separated list of target platforms.
PLATFORMS=instagram,pinterest,x
# How many topics -> posts per day. 3 topics x N platforms.
TOPICS_PER_DAY=3

# ------------------------------------------------------------
# CONTENT SOURCE — bring your own data source
# ------------------------------------------------------------
# Which source provider feeds trend signals into the pipeline:
#   rss      = pull from the RSS/Atom feeds in SOURCE_FEEDS (default)
#   vectordb = retrieve rows from a Postgres + pgvector knowledge base
#   none     = no external signals (agents work from brand context only)
#   a dotted path (e.g. mypkg.mymodule:MyProvider) = your own implementation
SOURCE_PROVIDER=rss
# Comma-separated RSS/Atom feed URLs (used when SOURCE_PROVIDER=rss).
SOURCE_FEEDS=https://www.theguardian.com/world/rss

# --- VectorDB provider (only needed when SOURCE_PROVIDER=vectordb) ---
# Cloud SQL Postgres instance with the pgvector extension.
# Connection name format: project:region:instance
WARDROBE_DB_CONNECTION_NAME=
WARDROBE_DB_NAME=
WARDROBE_DB_USER=postgres
WARDROBE_DB_PASSWORD=
# Use IAM database auth instead of a password (recommended).
WARDROBE_DB_USE_IAM=FALSE
WARDROBE_DB_PRIVATE_IP=FALSE
# The table holding your knowledge base rows, the embedding column, and the
# text columns to surface to the agents (comma-separated).
WARDROBE_DB_TABLE=knowledge_base
WARDROBE_DB_EMBED_COLUMN=embedding
WARDROBE_DB_TEXT_COLUMNS=title,body
# How many rows to retrieve per query.
WARDROBE_TOP_K=12
# Embeddings must use the SAME model the stored vectors were built with.
WARDROBE_EMBED_PROVIDER=openai
WARDROBE_EMBED_MODEL=text-embedding-3-small
WARDROBE_EMBED_DIM=1536
# Required when WARDROBE_EMBED_PROVIDER=openai.
OPENAI_API_KEY=

# ------------------------------------------------------------
# TELEGRAM BOT (mobile approval interface)
# Create a bot with @BotFather -> /newbot
# Get your chat ID by messaging @userinfobot
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ------------------------------------------------------------
# BUFFER (publishing passthrough to Instagram / Pinterest / X)
# Personal API Key: publish.buffer.com/settings/api -> Personal Keys -> New Key
# Channel IDs: run the GraphQL query in the README to get them.
# ------------------------------------------------------------
BUFFER_ACCESS_TOKEN=
BUFFER_INSTAGRAM_CHANNEL_ID=
BUFFER_PINTEREST_CHANNEL_ID=
BUFFER_X_CHANNEL_ID=

# ------------------------------------------------------------
# TIMEZONE for publish-slot calculation
# ------------------------------------------------------------
LOCAL_TZ=UTC

# ------------------------------------------------------------
# PIPELINE MODE (all optional; defaults in config.py)
# ------------------------------------------------------------
# "department" = multi-agent department (default). "phase1" = linear baseline.
PIPELINE_MODE=department

# Evaluator-optimizer critic loop bounds.
CRITIC_MAX_ITERATIONS=3
CRITIC_PASS_SCORE=4

# ------------------------------------------------------------
# REGIONAL INTELLIGENCE (injected into briefs + content prompts)
# ------------------------------------------------------------
REGION=Global
LOCALE=en
# Hemisphere drives season inference (summer/winter flip across the equator).
HEMISPHERE=northern
# Comma-separated cultural moments to be aware of (leave blank if not relevant).
REGIONAL_HOLIDAYS=

# ------------------------------------------------------------
# ANTI-SPAM GUARDRAILS
# ------------------------------------------------------------
DUPLICATE_SIMILARITY_THRESHOLD=0.82
DEDUP_LOOKBACK=40
MAX_LINKS_PER_CAPTION=1

# ------------------------------------------------------------
# DURABLE PUBLISH RETRY (Performance Monitor)
# ------------------------------------------------------------
RETRY_DELAY_MINUTES=15
MAX_PUBLISH_RETRIES=1
